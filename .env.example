AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

UPLOAD_PATH=./app/storage/uploads
METADATA_PATH=./app/storage/metadata

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Retrieval (multi-query, rerank, MMR diversity)
RETRIEVAL_CANDIDATE_K=24
RETRIEVAL_MAX_CONTEXT_CHUNKS=8
RETRIEVAL_MULTI_QUERY=1
RETRIEVAL_MIN_SCORE=0.32
RETRIEVAL_SCORE_GAP=0.12
RETRIEVAL_MMR_LAMBDA=0.72

FLASK_DEBUG=0
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
MAX_UPLOAD_BYTES=26214400

# Comma-separated origins for production CORS (e.g. https://app.example.com)
ALLOWED_ORIGINS=
COOKIE_SECURE=1
COOKIE_SAMESITE=Lax

# Rate limits (Flask-Limiter format)
RATE_LIMIT_ENABLED=1
RATE_LIMIT_LOGIN=5 per minute
RATE_LIMIT_REGISTER=3 per hour
RATE_LIMIT_CHAT=30 per minute
RATE_LIMIT_SEARCH=60 per minute
RATE_LIMIT_INGEST_FILE=10 per hour
RATE_LIMIT_INGEST_DB=5 per hour
RATE_LIMIT_REFRESH=10 per minute
# Use redis://redis:6379/0 with docker compose, or Azure Cache for Redis in production
RATE_LIMIT_STORAGE_URI=

MAX_QUERY_LENGTH=4000
MAX_CHAT_MESSAGES=200
MAX_CHAT_MESSAGE_CHARS=10000
MAX_TEXT_EXPORT_CHARS=500000

# Optional: load secrets from Azure Key Vault when env vars are unset
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
# AZURE_CLIENT_ID=<user-assigned-managed-identity-client-id>

# Audit logs: security.audit logger prints one JSON object per line (schema nano.audit.v1)
# Ship console output to Azure Log Analytics / Sentinel — no extra app code required.

AUTH_ENABLED=1
JWT_SECRET_KEY=change-me
JWT_ACCESS_EXPIRES_MIN=30
JWT_REFRESH_EXPIRES_DAYS=7

COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=rag_system
COSMOS_USERS_CONTAINER=users
COSMOS_TOKENS_CONTAINER=refresh_tokens
COSMOS_DOCUMENTS_CONTAINER=documents
COSMOS_VECTORS_CONTAINER=rag_chunks
# Requires Azure Vector Search for NoSQL enabled on the Cosmos account (see https://aka.ms/CosmosVectorSearch)
COSMOS_VECTOR_INIT_RETRIES=12
COSMOS_VECTOR_INIT_RETRY_SEC=10
COSMOS_CHATS_CONTAINER=chats
COSMOS_PREFERENCES_CONTAINER=user_preferences

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=nano-uploads

ANON_SESSION_TTL_HOURS=12
COSMOS_GUEST_SESSIONS_CONTAINER=guest_sessions

# Guest (not logged in) file uploads: 1 per UTC day, auto-deleted after TTL
GUEST_DAILY_UPLOAD_LIMIT=1
GUEST_DOCUMENT_TTL_HOURS=6
